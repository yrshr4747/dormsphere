# ============================================
# DormSphere — Environment Configuration
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────
# Local: postgresql://user:pass@localhost:5432/dormsphere
# Render: postgresql://user:pass@host/dormsphere
DATABASE_URL=postgresql://username:password@localhost:5432/dormsphere

# ── JWT Authentication ────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRY=24h

# ── Provably Fair Lottery ─────────────────────
LOTTERY_SEED=public-seed-2026-spring

# ── AES-256 Grievance Vault ───────────────────
GRIEVANCE_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
GRIEVANCE_IV=0123456789abcdef0123456789abcdef

# ── Outpass HMAC ──────────────────────────────
OUTPASS_SECRET=change-this-to-a-random-string

# ── SMTP (for OTP emails) ────────────────────
# Leave SMTP_USER empty to log OTPs to console instead of sending email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ── Server ────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Frontend Environment (set in Vercel dashboard) ──
# VITE_API_URL=https://your-backend.onrender.com/api
# VITE_SOCKET_URL=https://your-backend.onrender.com
